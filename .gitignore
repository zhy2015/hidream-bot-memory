# Ignore heavy or temporary directories
downloads/
metal-anchor-monorepo/
gateway-guardian/
puaclaw-repo/
skills/viva-gen/
test_*.py

# In case there are large old projects hanging around
# Note: projects/ directory is used for URI project:// namespace
# Only track MEMORY.md files, not the actual project code
projects/*/
!projects/*/MEMORY.md
!projects/*/
!projects/

# Ignore node_modules / venvs globally
node_modules/
venv/
.venv/
__pycache__/
*.pyc

# Local runtime logs
*.log
